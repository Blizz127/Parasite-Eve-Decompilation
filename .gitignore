# Game images / copyrighted input
*.bin
*.cue
*.iso
*.img
*.img.zip
*.ccd
*.sub
*.chd
rom/image/*
!rom/image/.gitkeep

# Local editor / agent rule files dropped in the tree by mistake
decomp.mdc

# Extracted game data
assets/*
!assets/.gitkeep

# Build/generated output
build/
asm/
linkers/
expected/
.splache
# splat's auto-generated symbol/function lists (written to repo root)
undefined_funcs_auto.txt
undefined_syms_auto.txt
*.o
*.elf
*.map
*.ninja
build.ninja
rules.ninja
compile_commands.json

# Local tooling/cache
__pycache__/
*.pyc
.venv/
.env
.DS_Store

# splat boilerplate copied into include/ on split (keep include/.gitkeep)
include/*.inc
include/*.h

# Era compiler toolchain (fetched by scripts/setup_era.sh) — ignore everything,
# EXCEPT the maspsx package file(s) that carry local patches. Git cannot
# re-include files inside an ignored directory, so this is written as
# per-level negations. setup_era.sh re-clones upstream AROUND the tracked file.
tools/era/*
!tools/era/maspsx/
tools/era/maspsx/*
!tools/era/maspsx/maspsx/
tools/era/maspsx/maspsx/*
!tools/era/maspsx/maspsx/__init__.py
!tools/era/maspsx/tests/
tools/era/maspsx/tests/*
!tools/era/maspsx/tests/test_fill_store_delay_slot.py
